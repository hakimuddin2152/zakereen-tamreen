generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GOD
  ADMIN
  PARTY_MEMBER
}

enum KalaamCategory {
  MARASIYA
  SALAAM
  MADEH
  MISC
}

enum MemberGrade {
  A
  B
  C
  D
}

model User {
  id          String       @id @default(cuid())
  username    String       @unique
  displayName String
  partyName   String?
  password    String
  role        Role         @default(PARTY_MEMBER)
  grade       MemberGrade?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  attendances      SessionAttendee[]
  evaluations      ReciterEvaluation[]
  prerequisites    KalaamPrerequisite[]
  kalaamRecordings KalaamRecording[]
}

model Kalaam {
  id            String         @id @default(cuid())
  title         String
  category      KalaamCategory @default(MISC)
  recitedBy     String?
  pdfLink       String?
  pdfFileKey    String?
  pdfFileName   String?
  audioFileKey  String?
  audioFileName String?
  highestNote   String?
  lowestNote    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  sessionKalaams SessionKalaam[]
  prerequisites  KalaamPrerequisite[]
  evaluations    ReciterEvaluation[]
  recordings     KalaamRecording[]
}

model Session {
  id        String   @id @default(cuid())
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kalaams     SessionKalaam[]
  attendees   SessionAttendee[]
  evaluations ReciterEvaluation[]
}

model SessionKalaam {
  id        String  @id @default(cuid())
  sessionId String
  kalaamId  String

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kalaam    Kalaam  @relation(fields: [kalaamId], references: [id])

  @@unique([sessionId, kalaamId])
}

model KalaamPrerequisite {
  id        String  @id @default(cuid())
  userId    String
  kalaamId  String
  lehenDone Boolean @default(false)
  hifzDone  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kalaam    Kalaam @relation(fields: [kalaamId], references: [id], onDelete: Cascade)

  @@unique([userId, kalaamId])
}

model SessionAttendee {
  id        String  @id @default(cuid())
  sessionId String
  userId    String

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

model ReciterEvaluation {
  id            String   @id @default(cuid())
  sessionId     String
  userId        String
  kalaamId      String?
  ranking       Int?
  voiceRange    String?
  audioFileKey  String?
  audioFileName String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session       Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id])
  kalaam        Kalaam? @relation(fields: [kalaamId], references: [id])

  @@unique([sessionId, userId, kalaamId])
}

model KalaamRecording {
  id        String   @id @default(cuid())
  userId    String
  kalaamId  String
  fileKey   String
  fileName  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kalaam Kalaam @relation(fields: [kalaamId], references: [id], onDelete: Cascade)
}

